# Pubwave Editor — Next.js example AI proxy config
#
# Copy to `.env` (or `.env.local`) and uncomment ONE provider block.
# Both filenames are gitignored at repo root, so either is safe.
# For deployments, set the same vars as system env vars on your platform
# (Vercel / Docker / k8s) — they take precedence over any .env file.
#
# -----------------------------------------------------------------------
# How env vars map to proxy paths
# -----------------------------------------------------------------------
# The catch-all proxy at /api/ai/[...path] dispatches by URL prefix:
#
#   /api/ai/openai/*    →  reads  OPENAI_API_KEY     +  OPENAI_BASE_URL
#                          (BASE_URL defaults to https://api.openai.com/v1
#                           — only OpenAI itself can skip it. Everything
#                           else MUST set BASE_URL to the upstream.)
#
#   /api/ai/anthropic/* →  reads  ANTHROPIC_API_KEY  +  ANTHROPIC_BASE_URL (optional)
#                                                    +  ANTHROPIC_VERSION  (optional)
#
#   /api/ai/gemini/*    →  reads  GOOGLE_API_KEY     +  GOOGLE_BASE_URL    (optional)
#
# Switch the active provider in EditorClientComponent.tsx by changing
# `baseURL` on the client adapter:
#   createAdapter({ provider: 'openai',    baseURL: '/api/ai/openai' })
#   createAdapter({ provider: 'anthropic', baseURL: '/api/ai/anthropic' })
#   createAdapter({ provider: 'gemini',    baseURL: '/api/ai/gemini' })
#
# Remember: the model id is set in the CLIENT (`defaultModel`), NOT here.

# =====================================================================
# OpenAI (official) — only the key is required
# =====================================================================
# OPENAI_API_KEY=sk-replace-me
# defaultModel:  gpt-4o-mini | gpt-4o | o3-mini

# =====================================================================
# OpenRouter — single key for OpenAI / Claude / Gemini / Llama / DeepSeek …
# Routes through /api/ai/openai (it speaks the OpenAI protocol).
# REQUIRES BOTH KEY AND BASE_URL.
# =====================================================================
# OPENAI_API_KEY=sk-or-v1-replace-me
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# defaultModel examples:
#   openai/gpt-4o-mini
#   anthropic/claude-sonnet-4.5
#   google/gemini-2.5-flash
#   meta-llama/llama-3.3-70b-instruct
#   deepseek/deepseek-chat

# =====================================================================
# Anthropic Claude (native /api/ai/anthropic — only the key is required)
# =====================================================================
# ANTHROPIC_API_KEY=sk-ant-replace-me
# ANTHROPIC_BASE_URL=https://api.anthropic.com   # optional override
# ANTHROPIC_VERSION=2023-06-01                   # optional override
# defaultModel:  claude-sonnet-4-6 | claude-opus-4-7 | claude-haiku-4-5

# =====================================================================
# Google Gemini (native /api/ai/gemini — only the key is required)
# =====================================================================
# GOOGLE_API_KEY=AIza-replace-me
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta   # optional
# defaultModel:  gemini-2.5-flash | gemini-2.5-pro | gemini-2.0-flash

# =====================================================================
# DeepSeek — via /api/ai/openai. REQUIRES BOTH KEY AND BASE_URL.
# =====================================================================
# OPENAI_API_KEY=sk-replace-me
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# defaultModel:  deepseek-chat | deepseek-reasoner

# =====================================================================
# Moonshot (Kimi) — via /api/ai/openai. REQUIRES BOTH KEY AND BASE_URL.
# =====================================================================
# OPENAI_API_KEY=sk-replace-me
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# defaultModel:  moonshot-v1-8k | moonshot-v1-32k | moonshot-v1-128k

# =====================================================================
# Zhipu GLM (智谱) — via /api/ai/openai. REQUIRES BOTH KEY AND BASE_URL.
# =====================================================================
# OPENAI_API_KEY=replace-me.replace-me
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# defaultModel:  glm-4-plus | glm-4-flash | glm-4-air

# =====================================================================
# Qwen DashScope (阿里通义) — via /api/ai/openai. REQUIRES BOTH KEY
# AND BASE_URL (must use the compatible-mode path).
# =====================================================================
# OPENAI_API_KEY=sk-replace-me
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# defaultModel:  qwen-plus | qwen-max | qwen-turbo

# =====================================================================
# Volcengine Doubao (火山方舟豆包) — via /api/ai/openai.
# REQUIRES BOTH KEY AND BASE_URL. Model id = your endpoint id.
# =====================================================================
# OPENAI_API_KEY=replace-me
# OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# defaultModel:  ep-2024xxxx-xxxxx   (your endpoint id from the console)

# =====================================================================
# SiliconFlow (硅基流动) — via /api/ai/openai. REQUIRES BOTH KEY AND BASE_URL.
# =====================================================================
# OPENAI_API_KEY=sk-replace-me
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# defaultModel:  Qwen/Qwen2.5-72B-Instruct
#                deepseek-ai/DeepSeek-V3
#                meta-llama/Llama-3.3-70B-Instruct

# =====================================================================
# Groq — free tier, very fast. via /api/ai/openai.
# REQUIRES BOTH KEY AND BASE_URL.
# =====================================================================
# OPENAI_API_KEY=gsk_replace-me
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# defaultModel:  llama-3.3-70b-versatile | mixtral-8x7b-32768

# =====================================================================
# Together AI — via /api/ai/openai. REQUIRES BOTH KEY AND BASE_URL.
# =====================================================================
# OPENAI_API_KEY=replace-me
# OPENAI_BASE_URL=https://api.together.xyz/v1
# defaultModel:  meta-llama/Llama-3.3-70B-Instruct-Turbo

# =====================================================================
# Local Ollama — no key, no proxy needed. Switch the CLIENT to:
#   createAdapter({ provider: 'ollama', baseURL: 'http://localhost:11434/v1' })
# Nothing to set in this file.
# =====================================================================
